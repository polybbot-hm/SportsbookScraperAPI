    "/health": {
      "get": {
        "summary": "Health",
        "description": "Comprueba que la API está viva.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookmakerResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "active": {
            "type": "boolean",
            "title": "Active"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "slug",
          "active"
        ],
        "title": "BookmakerResponse",
        "description": "Casa de apuestas disponible."
      },
      "CompareItemResponse": {
        "properties": {
          "partido": {
            "type": "string",
            "title": "Partido"
          },
          "mercado": {
            "type": "string",
            "title": "Mercado"
          },
          "selection": {
            "type": "string",
            "title": "Selection"
          },
          "fecha": {
            "type": "string",
            "title": "Fecha"
          },
          "cuotas_por_casa": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Cuotas Por Casa",
            "description": "bookmaker -> cuota"
          }
        },
        "type": "object",
        "required": [
          "partido",
          "mercado",
          "selection",
          "fecha",
          "cuotas_por_casa"
        ],
        "title": "CompareItemResponse",
        "description": "Comparación: partido, mercado, selection, cuotas por casa."
      },
      "EventResponse": {
        "properties": {
          "external_id": {
            "type": "string",
            "title": "External Id"
          },
          "partido": {
            "type": "string",
            "title": "Partido"
          },
          "league_name": {
            "type": "string",
            "title": "League Name"
          },
          "sport": {
            "type": "string",
            "title": "Sport"
          }
        },
        "type": "object",
        "required": [
          "external_id",
          "partido",
          "league_name",
          "sport"
        ],
        "title": "EventResponse",
        "description": "Evento (partido)."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "OddsItemResponse": {
        "properties": {
          "fecha": {
            "type": "string",
            "title": "Fecha",
            "description": "ISO timestamp del scraping"
          },
          "partido": {
            "type": "string",
            "title": "Partido",
            "description": "Local vs Visitante"
          },
          "mercado": {
            "type": "string",
            "title": "Mercado",
            "description": "Nombre del mercado"
          },
          "cuota": {
            "type": "number",
            "title": "Cuota",
            "description": "Valor de la cuota"
          },
          "selection": {
            "type": "string",
            "title": "Selection",
            "description": "Selección (ej: Local, Visitante)"
          },
          "bookmaker": {
            "type": "string",
            "title": "Bookmaker",
            "description": "Casa de apuestas"
          }
        },
        "type": "object",
        "required": [
          "fecha",
          "partido",
          "mercado",
          "cuota",
          "selection",
          "bookmaker"
        ],
        "title": "OddsItemResponse",
        "description": "Una cuota en formato estándar: fecha, partido, mercado, cuota."
      },
      "PartidoSummary": {
        "properties": {
          "partido": {
            "type": "string",
            "title": "Partido"
          },
          "categorias": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Categorias",
            "description": "categoria -> nº mercados"
          },
          "total_mercados": {
            "type": "integer",
            "title": "Total Mercados"
          }
        },
        "type": "object",
        "required": [
          "partido",
          "categorias",
          "total_mercados"
        ],
        "title": "PartidoSummary",
        "description": "Resumen de un partido scrapeado."
      },
      "ScrapeRequest": {
        "properties": {
          "bookmaker": {
            "type": "string",
            "title": "Bookmaker",
            "description": "Casa de apuestas: codere, paf, retabet"
          },
          "league_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "League Name",
            "description": "Filtrar por liga; si se omite, todas las ligas con mercado"
          }
        },
        "type": "object",
        "required": [
          "bookmaker"
        ],
        "title": "ScrapeRequest",
        "description": "Request para lanzar scraping manual."
      },
      "ScrapeStatusResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "running | completed | idle"
          },
          "last_run": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Run"
          },
          "bookmaker": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bookmaker"
          },
          "message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "ScrapeStatusResponse",
        "description": "Estado del último scraping."
      },
      "ScrapeSummaryResponse": {
        "properties": {
          "bookmaker": {
            "type": "string",
            "title": "Bookmaker"
          },
          "liga": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Liga"
          },
          "fecha_scraping": {
            "type": "string",
            "title": "Fecha Scraping"
          },
          "total_cuotas_insertadas": {
            "type": "integer",
            "title": "Total Cuotas Insertadas"
          },
          "partidos_scrapeados": {
            "type": "integer",
            "title": "Partidos Scrapeados"
          },
          "detalle": {
            "items": {
              "$ref": "#/components/schemas/PartidoSummary"
            },
            "type": "array",
            "title": "Detalle"
          }
        },
        "type": "object",
        "required": [
          "bookmaker",
          "liga",
          "fecha_scraping",
          "total_cuotas_insertadas",
          "partidos_scrapeados",
          "detalle"
        ],
        "title": "ScrapeSummaryResponse",
        "description": "Resumen de un scraping masivo (ej: LaLiga del día)."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}