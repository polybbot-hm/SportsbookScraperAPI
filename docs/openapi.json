{
  "openapi": "3.1.0",
  "info": {
    "title": "SportsbookScraperAPI",
    "description": "API para scraping de mercados de casas de apuestas deportivas. Mercados: principales, estadísticas, corners, handicap, resultado final, equipos, faltas. Casas: Codere (activo), Paf y Retabet (placeholder). Persistencia en Supabase (tabla odds_raw).",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/scrape": {
      "post": {
        "tags": [
          "scrape"
        ],
        "summary": "Scraping manual genérico",
        "description": "Ejecuta scraping de los mercados configurados para la casa y liga indicadas. Persiste en Supabase si DATABASE_URL está configurada.",
        "operationId": "run_scrape_api_v1_scrape_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/OddsItemResponse"
                  },
                  "type": "array",
                  "title": "Response Run Scrape Api V1 Scrape Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/scrape/laliga-hoy": {
      "post": {
        "tags": [
          "scrape"
        ],
        "summary": "Scrapear todos los partidos de LaLiga del día",
        "description": "Recopila todos los partidos de Primera División de hoy, extrae las cuotas de las categorías configuradas (PRINCIPALES, ESTADÍSTICAS, CORNERS, HANDICAP, RESULTADO FINAL, EQUIPOS) e inserta en Supabase. Devuelve un resumen con el detalle por partido y categoría.",
        "operationId": "scrape_laliga_hoy_api_v1_scrape_laliga_hoy_post",
        "parameters": [
          {
            "name": "bookmaker",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Casa de apuestas (por defecto: codere)",
              "default": "codere",
              "title": "Bookmaker"
            },
            "description": "Casa de apuestas (por defecto: codere)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeSummaryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/scrape/status": {
      "get": {
        "tags": [
          "scrape"
        ],
        "summary": "Estado del último scraping",
        "operationId": "scrape_status_api_v1_scrape_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/odds": {
      "get": {
        "tags": [
          "odds"
        ],
        "summary": "Listar cuotas actuales",
        "description": "Obtiene las cuotas más recientes. Filtros: bookmaker, league_name, event_id.",
        "operationId": "get_odds_api_v1_odds_get",
        "parameters": [
          {
            "name": "bookmaker",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Casa de apuestas",
              "title": "Bookmaker"
            },
            "description": "Casa de apuestas"
          },
          {
            "name": "league_name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Nombre de la liga",
              "title": "League Name"
            },
            "description": "Nombre de la liga"
          },
          {
            "name": "event_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ID externo del evento",
              "title": "Event Id"
            },
            "description": "ID externo del evento"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OddsItemResponse"
                  },
                  "title": "Response Get Odds Api V1 Odds Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/odds/{event_id}/history": {
      "get": {
        "tags": [
          "odds"
        ],
        "summary": "Histórico de cuotas de un evento",
        "operationId": "get_odds_history_api_v1_odds__event_id__history_get",
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Event Id"
            }
          },
          {
            "name": "bookmaker",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Bookmaker"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OddsItemResponse"
                  },
                  "title": "Response Get Odds History Api V1 Odds  Event Id  History Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/compare/{event_id}": {
      "get": {
        "tags": [
          "compare"
        ],
        "summary": "Comparar cuotas de un evento (todas las casas)",
        "operationId": "compare_by_event_api_v1_compare__event_id__get",
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Event Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OddsItemResponse"
                  },
                  "title": "Response Compare By Event Api V1 Compare  Event Id  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/compare": {
      "get": {
        "tags": [
          "compare"
        ],
        "summary": "Comparación global (cuotas por casa por mercado)",
        "operationId": "compare_global_api_v1_compare_get",
        "parameters": [
          {
            "name": "league_name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "League Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CompareItemResponse"
                  },
                  "title": "Response Compare Global Api V1 Compare Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bookmakers": {
      "get": {
        "tags": [
          "bookmakers"
        ],
        "summary": "Listar casas de apuestas",
        "operationId": "list_bookmakers_api_v1_bookmakers_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/BookmakerResponse"
                  },
                  "type": "array",
                  "title": "Response List Bookmakers Api V1 Bookmakers Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/leagues": {
      "get": {
        "tags": [
          "bookmakers"
        ],
        "summary": "Ligas con mercado de faltas",
        "description": "Ligas que se sabe que tienen el mercado (cache en DB).",
        "operationId": "list_leagues_api_v1_leagues_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "title": "Response List Leagues Api V1 Leagues Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/events": {
      "get": {
        "tags": [
          "bookmakers"
        ],
        "summary": "Listar eventos con odds",
        "operationId": "list_events_api_v1_events_get",
        "parameters": [
          {
            "name": "league_name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "League Name"
            }
          },
          {
            "name": "bookmaker",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Bookmaker"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EventResponse"
                  },
                  "title": "Response List Events Api V1 Events Get"
                }
              }
            }
          },
          "422": {
