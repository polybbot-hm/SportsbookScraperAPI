# API
APP_NAME=SportsbookScraperAPI
DEBUG=false

# Supabase
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_KEY=<tu-anon-key>

# Base de datos directa (opcional, alternativa a supabase_url+key)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Caché
CACHE_TTL_SECONDS=300

# Scraping
SCRAPE_DELAY_MIN=0.3
SCRAPE_DELAY_MAX=0.8
# Cron: cada 6 horas (ejemplo, no usado por el job diario de LaLiga)
SCRAPE_CRON=0 */6 * * *

# Cron diario LaLiga
# Ruta al fichero JSON con las fechas de jornadas de Primera División
CALENDAR_FILE_PATH=config/laliga_calendar.json
# Zona horaria para el job (el disparo es a las 11:00 Europe/Madrid)
JOB_TIMEZONE=Europe/Madrid
