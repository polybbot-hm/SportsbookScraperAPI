# API
APP_NAME=SportsbookScraperAPI
DEBUG=false

# ── MongoDB (principal) ────────────────────────────────────────────────────────
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/
# Local: mongodb://localhost:27017/
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/

# ── Supabase (legacy, solo si no usas MongoDB) ────────────────────────────────
# SUPABASE_URL=https://<tu-proyecto>.supabase.co
# SUPABASE_KEY=<tu-anon-key>

# ── PostgreSQL directo (legacy) ───────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Rutas de configuración YAML (override por entorno) ────────────────────────
# APP_CONFIG_PATH=config/app.yaml
# LEAGUES_CONFIG_PATH=config/leagues.yaml
# BOOKMAKERS_CONFIG_DIR=config/bookmakers

# ── Job diario ────────────────────────────────────────────────────────────────
JOB_TIMEZONE=Europe/Madrid
